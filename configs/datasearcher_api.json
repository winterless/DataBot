{
  "time_sweep": {
    "hf_limit": 100,
    "gh_limit": 150
  },
  "deep_scan": {
    "enabled": true,
    "max_pages": 5,
    "readme_sample_size": 30,
    "code_search_limit": 50
  },
  "default_provider": "aliyun",
  "providers": {
    "local": {
      "host": "127.0.0.1",
      "port": 8000,
      "base_url": ""
    },
    "aliyun": {
      "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
      "model": "qwen-plus",
      "api_key_env": "DASHSCOPE_API_KEY"
    }
  },
  "request": {
    "timeout": 600,
    "retries": 2,
    "verify_hf_exists": true
  },
  "selection": {
    "recall_pool_size": 12000,
    "download_size": 10,
    "preferred_size": {
      "min_mb": 1000,
      "max_mb": 50000,
      "exclude_size_human": ["n>1t", "unknown", "100b<n", "1b<n", "100m<n"]
    }
  },
  "recall_pool_output": "out/datasearcher/recall_pool.jsonl",
  "llm_trace_output": "out/datasearcher/llm_trace.json",
  "source_policy_file": "configs/source_policy.json",
  "source_policy": {
    "huggingface": 6,
    "github": 4
  },
  "prompt": "",
  "prompt_file": "configs/prompts/datasearcher_prompt.txt"
}
